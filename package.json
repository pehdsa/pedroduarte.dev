{
  "name": "pedroduarte-dev",
  "version": "1.0.0",
  "description": "Pedro Duarte — Full Stack Developer Portfolio",
  "scripts": {
    "build:css": "tailwindcss -i css/tailwind-input.css -o css/tailwind.css --minify",
    "watch:css": "tailwindcss -i css/tailwind-input.css -o css/tailwind.css --watch",
    "dev": "concurrently -n css,vite -c yellow,cyan \"npm:watch:css\" \"vite\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "lucide": "^1.8.0"
  }
}
